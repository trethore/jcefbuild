# escape=`
ARG version=ltsc2022
FROM mcr.microsoft.com/dotnet/framework/runtime:4.8.1-20221213-windowsservercore-$version

SHELL ["cmd", "/S", "/C"]

ARG TARGETARCH=amd64

ENV chocolateyUseWindowsCompression=false
ENV CHOCO_CACHE_DIR=C:\chococache
ENV CHOCO_COMMON_ARGS=--confirm --limit-output --timeout 216000
ENV VS_BUILDTOOLS_PATH=%ProgramFiles(x86)%\Microsoft Visual Studio\2022\BuildTools

RUN powershell -Command `
    "iex ((new-object net.webclient).DownloadString('https://chocolatey.org/install.ps1')); `
    choco feature disable --name showDownloadProgress"

RUN choco config set cachelocation %CHOCO_CACHE_DIR%

RUN choco install microsoft-openjdk17 `
    --version=17.0.18 `
    --params "'INSTALLDIR=C:\jdk-17'" `
    %CHOCO_COMMON_ARGS% `
    && rmdir /S /Q %CHOCO_CACHE_DIR%

RUN if /I "%TARGETARCH%"=="arm64" powershell -Command `
    "$ProgressPreference = 'SilentlyContinue'; `
    Invoke-WebRequest -Uri 'https://aka.ms/download-jdk/microsoft-jdk-17.0.18-windows-aarch64.zip' -OutFile 'C:\microsoft-jdk-17-windows-aarch64.zip'; `
    Expand-Archive -Path 'C:\microsoft-jdk-17-windows-aarch64.zip' -DestinationPath 'C:\jdk-17-arm64-tmp'; `
    $jdkDir = (Get-ChildItem 'C:\jdk-17-arm64-tmp' | Select-Object -First 1).FullName; `
    Move-Item -Path $jdkDir -Destination 'C:\jdk-17-arm64'; `
    Remove-Item 'C:\microsoft-jdk-17-windows-aarch64.zip' -Force; `
    Remove-Item 'C:\jdk-17-arm64-tmp' -Recurse -Force"

RUN choco install cmake.install `
    --version=3.21.6 `
    --installargs '"ADD_CMAKE_TO_PATH=System"' `
    %CHOCO_COMMON_ARGS% `
    && rmdir /S /Q %CHOCO_CACHE_DIR%

RUN choco install ninja `
    %CHOCO_COMMON_ARGS% `
    && rmdir /S /Q %CHOCO_CACHE_DIR%

RUN choco install git `
    %CHOCO_COMMON_ARGS% `
    && rmdir /S /Q %CHOCO_CACHE_DIR%

RUN choco install python `
    --version=3.10.11 `
    %CHOCO_COMMON_ARGS% `
    && rmdir /S /Q %CHOCO_CACHE_DIR%

RUN curl -SL --output C:\vs_buildtools.exe https://aka.ms/vs/17/release/vs_buildtools.exe `
    && if /I "%TARGETARCH%"=="arm64" ( `
        start /w "" C:\vs_buildtools.exe `
            --quiet --wait --norestart --nocache `
            --installPath "%VS_BUILDTOOLS_PATH%" `
            --add Microsoft.VisualStudio.Workload.VCTools `
            --add Microsoft.VisualStudio.Component.VC.ATL `
            --add Microsoft.VisualStudio.Component.VC.Tools.ARM64 `
            --add Microsoft.VisualStudio.Component.VC.ATL.ARM64 `
            --includeRecommended `
            --remove Microsoft.VisualStudio.Component.Windows10SDK.10240 `
            --remove Microsoft.VisualStudio.Component.Windows10SDK.10586 `
            --remove Microsoft.VisualStudio.Component.Windows10SDK.14393 `
            --remove Microsoft.VisualStudio.Component.Windows81SDK `
        || IF "%ERRORLEVEL%"=="3010" EXIT 0 `
    ) else ( `
        start /w "" C:\vs_buildtools.exe `
            --quiet --wait --norestart --nocache `
            --installPath "%VS_BUILDTOOLS_PATH%" `
            --add Microsoft.VisualStudio.Workload.VCTools `
            --add Microsoft.VisualStudio.Component.VC.ATL `
            --includeRecommended `
            --remove Microsoft.VisualStudio.Component.Windows10SDK.10240 `
            --remove Microsoft.VisualStudio.Component.Windows10SDK.10586 `
            --remove Microsoft.VisualStudio.Component.Windows10SDK.14393 `
            --remove Microsoft.VisualStudio.Component.Windows81SDK `
        || IF "%ERRORLEVEL%"=="3010" EXIT 0 `
    ) `
    && del /F /Q C:\vs_buildtools.exe `
    && if exist %CHOCO_CACHE_DIR% rmdir /S /Q %CHOCO_CACHE_DIR%

WORKDIR C:/

#Copy cmake patching script
COPY scripts/patch/patch_cmake.py .
COPY patch/CMakeLists.txt.patch .

#Copy and launch run script
COPY scripts/run/run_windows.bat .
ENTRYPOINT ["run_windows.bat"]
