FROM debian:bullseye AS stage

#Declare architecture argument (arm64 or amd64)
ARG TARGETARCH

#Step 1: Install required tools and libs
ENV DEBIAN_FRONTEND=noninteractive
ENV TOOLS="python3 python-is-python3 cmake-latest git gcc build-essential libgtk2.0-dev ninja-build rsync curl libgbm-dev libxkbcommon-dev libpango1.0-dev libcairo-dev ca-certificates"
ENV LIBS="libnss3 libnspr4 libatk-bridge2.0-0 libdrm2 libxkbcommon0 libgbm1 libasound2 libatspi2.0-0 libxshmfence1"
RUN apt-get -q update && \
    apt-get -q install -y --fix-missing -o Acquire::Retries=5 --no-install-recommends openjdk-17-jdk $TOOLS $LIBS && \
    cmake --version && \
    rm -rf /var/lib/apt/lists/*

#Declare build type argument (Release or Debug)
ARG BUILD_TYPE

#Declare git args
ARG REPO
ARG REF

WORKDIR /builder
#Copy existing sources, if any
COPY jcef /jcef

#Copy cmake patching script
COPY scripts/lib/retry.sh .
COPY scripts/lib/jcef.sh .
COPY scripts/patches/patch_cmake.py .
COPY scripts/patches/patch_jcef_tools.py .
COPY scripts/patches/CMakeLists.txt.patch .

#Copy and launch run script
COPY scripts/docker/run_linux.sh .
RUN chmod +x run_linux.sh
RUN ./run_linux.sh

#Export built files
FROM scratch AS export-stage
COPY --from=stage /jcef/binary_distrib.tar.gz .
