ARG WINDOWS_VERSION=ltsc2022
ARG TARGETARCH=amd64
FROM mcr.microsoft.com/dotnet/framework/runtime:4.8.1-20221213-windowsservercore-$WINDOWS_VERSION

LABEL jcefbuild=true

ENV chocolateyUseWindowsCompression false
# Keep temp/cache paths short to reduce path-length issues for VS bootstrapper.
ENV TEMP=C:\\Temp
ENV TMP=C:\\Temp
RUN if not exist C:\\Temp mkdir C:\\Temp
# Allow extraction/install paths longer than 260 characters to avoid ImportLayer
# failures when Chocolatey unpacks Visual Studio payloads.
RUN reg add "HKLM\SYSTEM\CurrentControlSet\Control\FileSystem" /v LongPathsEnabled /t REG_DWORD /d 1 /f

RUN powershell -Command \
    iex ((new-object net.webclient).DownloadString('https://chocolatey.org/install.ps1')); \
    choco feature disable --name showDownloadProgress

RUN choco config set cachelocation C:\c

RUN choco install jdk8 -params "both=true" --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\c
COPY scripts/windows_download_arm64_jdk.bat windows_download_arm64_jdk.bat
RUN windows_download_arm64_jdk.bat && del windows_download_arm64_jdk.bat
RUN choco install cmake.install --version=3.19 --installargs '"ADD_CMAKE_TO_PATH=System"' --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\c
RUN choco install ninja --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\c
RUN choco install git --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\c
RUN choco install vswhere --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\c
RUN choco install python --version=3.7.2 --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\c
SHELL ["powershell", "-Command", "$ErrorActionPreference = 'Stop'; $ProgressPreference = 'SilentlyContinue';"]
RUN $components = @('Microsoft.VisualStudio.Workload.VCTools','Microsoft.VisualStudio.Component.VC.ATL','Microsoft.VisualStudio.Component.Windows11SDK.26100','Microsoft.VisualStudio.Component.VC.Tools.x86.x64','Microsoft.VisualStudio.Component.UCRT.Debug'); \
    if ($env:TARGETARCH -eq 'arm64') { $components += 'Microsoft.VisualStudio.Component.VC.Tools.ARM64' }; \
    $paramString = '--add ' + ($components -join ' --add ') + ' --includeRecommended --nocache --installPath C:\BuildTools'; \
    choco install visualstudio2022buildtools --package-parameters "$paramString" --confirm --limit-output --timeout 216000; \
    Remove-Item -Recurse -Force C:\c
SHELL ["cmd", "/S", "/C"]

WORKDIR C:/

# Copy cmake patching script
COPY scripts/patch_cmake.py .
COPY patch/CMakeLists.txt.patch .

# Copy and launch run script
COPY scripts/run_windows.bat .
ENTRYPOINT ["run_windows.bat"]