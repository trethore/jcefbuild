ARG version=ltsc2022
FROM mcr.microsoft.com/dotnet/framework/runtime:4.8.1-20221213-windowsservercore-$version

ARG TARGETARCH=amd64

ENV chocolateyUseWindowsCompression false

RUN powershell -Command \
    iex ((new-object net.webclient).DownloadString('https://chocolatey.org/install.ps1')); \
    choco feature disable --name showDownloadProgress

RUN choco config set cachelocation C:\chococache

RUN choco install jdk8 -params "both=true" --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\chococache
RUN choco install microsoft-openjdk11 --params "'INSTALLDIR=C:\jdk-11'" --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\chococache
RUN if /I "%TARGETARCH%"=="arm64" powershell -Command "$ProgressPreference = 'SilentlyContinue'; Invoke-WebRequest -Uri 'https://aka.ms/download-jdk/microsoft-jdk-11-windows-aarch64.zip' -OutFile 'C:\microsoft-jdk-11-windows-aarch64.zip'; Expand-Archive -Path 'C:\microsoft-jdk-11-windows-aarch64.zip' -DestinationPath 'C:\jdk-11-arm64-tmp'; $jdkDir = (Get-ChildItem 'C:\jdk-11-arm64-tmp' | Select-Object -First 1).FullName; Move-Item -Path $jdkDir -Destination 'C:\jdk-11-arm64'; Remove-Item 'C:\microsoft-jdk-11-windows-aarch64.zip' -Force; Remove-Item 'C:\jdk-11-arm64-tmp' -Recurse -Force"
RUN choco install cmake.install --version=3.19 --installargs '"ADD_CMAKE_TO_PATH=System"' --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\chococache
RUN choco install ninja --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\chococache
RUN choco install git --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\chococache
RUN choco install python --version=3.7.2 --confirm --limit-output --timeout 216000 && rmdir /S /Q C:\chococache
RUN if /I "%TARGETARCH%"=="arm64" (choco install visualstudio2022buildtools --package-parameters "--add Microsoft.VisualStudio.Workload.VCTools --add Microsoft.VisualStudio.Component.VC.ATL --add Microsoft.VisualStudio.Component.VC.Tools.ARM64 --add Microsoft.VisualStudio.Component.VC.ATL.ARM64 --includeRecommended" --confirm --limit-output --timeout 216000) else (choco install visualstudio2022buildtools --package-parameters "--add Microsoft.VisualStudio.Workload.VCTools --add Microsoft.VisualStudio.Component.VC.ATL --includeRecommended" --confirm --limit-output --timeout 216000) && rmdir /S /Q C:\chococache

WORKDIR C:/

#Copy cmake patching script
COPY scripts/patch_cmake.py .
COPY patch/CMakeLists.txt.patch .

#Copy and launch run script
COPY scripts/run_windows.bat .
ENTRYPOINT ["run_windows.bat"]
